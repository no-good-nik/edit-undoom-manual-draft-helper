{
  "manifest_version": 3,
  "name": "Edit Undoom Manual Draft Helper",
  "version": "0.1.0",
  "description": "Open the n8n manual event draft form with source and venue defaults from the current Instagram/Facebook/Bandsintown page.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://www.bandsintown.com/*",
    "https://n8n.editundoom.ca/*"
  ],
  "action": {
    "default_title": "Create Edit Undoom draft",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "src/icons/edit-undoom-icon-400.png",
      "48": "src/icons/edit-undoom-icon-400.png",
      "128": "src/icons/edit-undoom-icon-400.png"
    }
  },
  "options_page": "src/options.html",
  "icons": {
    "16": "src/icons/edit-undoom-icon-400.png",
    "48": "src/icons/edit-undoom-icon-400.png",
    "128": "src/icons/edit-undoom-icon-400.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "manual-draft-helper@editundoom.ca",
      "strict_min_version": "109.0"
    }
  }
}
